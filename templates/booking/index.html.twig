{% extends 'base.html.twig' %}

{% block title %}Hello BookingController!{% endblock %}

{% block body %}
    <section class="max-w-7xl bg-cover bg-center mx-auto rounded-3xl" style="background-image: url('{{ asset('media/site/3.jpg') }}')">
        <div class="lex min-h-full flex-col justify-center px-12 py-24 lg:px-8 bg-gray-800 bg-opacity-80 rounded-3xl">
            <div class="text-left mx-auto max-w-2xl py-10">
                {% for message in app.flashes('success') %}
                    <div class="rounded-md bg-green-50 p-4 mb-8 inline-block">
                        <div class="flex">
                            <div class="flex-shrink-0">
                                <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <div class="ml-3 text-sm font-medium text-green-800">
                                <p>{{ message }}</p>
                            </div>
                        </div>
                    </div>
                {% endfor %}
                <h2 class="text-4xl font-semibold leading-tight tracking-tight text-white sm:text-5xl">Besoin d'un conseil ?<br/> On vous rappelle !</h2>
                <p class="mt-6 text-lg leading-8 text-gray-300">Une conseillère ou un conseiller va vous rappeler immédiatement et gratuitement, durant les heures d’ouverture.</p>
                {{ form_start(form) }}
                    <div class="mt-4 sm:mt-8 sm:flex sm:max-w-md justify-start gap-x-2 sm:space-y-0 space-y-2">
                        <label class="sr-only">{{ form_label(form.phoneNumber, 'Numéro de téléphone') }}</label>
                        {{ form_widget(form.phoneNumber, {'attr': {'autocomplete':'tel', 'class':'min-w-0 flex-auto rounded-md border-0 bg-white px-5 py-3 text-gray-900 ring-1 ring-inset ring-white/10 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6 w-full sm:w-auto', 'placeholder': 'Numéro de téléphone'}}) }}
                        <button type="submit" class="flex-none rounded-md bg-primary px-5 py-3 text-sm font-semibold text-white hover:bg-primary-light focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary w-full sm:w-auto transition duration-100">Rappelez-moi</button>
                    </div>
                    <div class="text-red-400 text-sm mt-4">
                        <p>{{ form_errors(form.phoneNumber) }}</p>
                    </div>
                {{ form_end(form) }}
                <div class="sm:max-w-md mt-4">
                    <p class="text-xs text-gray-400">Vous déclarez avoir pris connaissance de la politique de confidentialité de Assurance Genevoise.</p>
                </div>
            </div>
        </div>
    </section>
    <section>
        <div class="mx-auto max-w-7xl lg:px-8 bg-primary rounded-3xl py-24 mt-5">
            <div class="mx-auto max-w-2xl lg:max-w-none px-10">
                <dl class="grid max-w-xl grid-cols-1 gap-x-10 gap-y-16 lg:max-w-none lg:grid-cols-3">
                    <div class="flex flex-col">
